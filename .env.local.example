# Google Maps JavaScript API key used by the browser to render the map.
# Must have "Maps JavaScript API" enabled. Because it ships to the client,
# restrict it by HTTP referrer (your-domain + http://localhost:3000) in the
# Google Cloud console.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIza...

# Key used by scripts/build-data.ts for the Google Geocoding API (rooftop pins).
# Must have "Geocoding API" enabled. Used server-side only, so it can be the same
# key or a separate, IP-restricted one. If unset, the script falls back to the
# free US Census geocoder (street-level).
GOOGLE_GEOCODING_API_KEY=AIza...
