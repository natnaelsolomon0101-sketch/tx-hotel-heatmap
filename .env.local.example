# Mapbox public token used by the browser to render the map (must be prefixed NEXT_PUBLIC_).
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_public_token

# Token used by scripts/build-data.ts for the Mapbox Geocoding API.
# Can be the same public token, or a separate token scoped to geocoding.
MAPBOX_GEOCODING_TOKEN=pk.your_mapbox_geocoding_token
