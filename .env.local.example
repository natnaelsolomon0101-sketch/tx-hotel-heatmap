# NOTE: the MAP ITSELF needs NO token. It renders with MapLibre GL + free CARTO
# basemaps, so the app works out of the box with no account.

# Optional: only used by scripts/build-data.ts IF you want to geocode with the
# Mapbox Geocoding API (higher hit rate than the free, no-key US Census geocoder).
# Leave unset to use the Census geocoder (GEOCODER=census) instead.
MAPBOX_GEOCODING_TOKEN=
